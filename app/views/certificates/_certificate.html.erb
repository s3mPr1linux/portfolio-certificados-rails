<div id="<%= dom_id certificate %>" class="w-full sm:w-auto my-5 space-y-5">
  <div>
    <strong class="block font-medium mb-1">Name:</strong>
    <%= certificate.name %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Issuer:</strong>
    <%= certificate.issuer %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Issue date:</strong>
    <%= certificate.issue_date %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Credential:</strong>
    <%= certificate.credential_id %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Validation url:</strong>
    <%= certificate.validation_url %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Description:</strong>
    <%= certificate.description %>
  </div>
</div>
