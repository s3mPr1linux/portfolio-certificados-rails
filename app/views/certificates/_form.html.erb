<%= form_with(model: certificate, class: "contents") do |form| %>
  <% if certificate.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-md mt-3">
      <h2><%= pluralize(certificate.errors.count, "error") %> prohibited this certificate from being saved:</h2>

      <ul class="list-disc ml-6">
        <% certificate.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="my-5">
    <%= form.label :name %>
    <%= form.text_field :name, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": certificate.errors[:name].none?, "border-red-400 focus:outline-red-600": certificate.errors[:name].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :issuer %>
    <%= form.text_field :issuer, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": certificate.errors[:issuer].none?, "border-red-400 focus:outline-red-600": certificate.errors[:issuer].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :issue_date %>
    <%= form.date_field :issue_date, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": certificate.errors[:issue_date].none?, "border-red-400 focus:outline-red-600": certificate.errors[:issue_date].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :credential_id %>
    <%= form.text_field :credential_id, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": certificate.errors[:credential_id].none?, "border-red-400 focus:outline-red-600": certificate.errors[:credential_id].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :validation_url %>
    <%= form.text_field :validation_url, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": certificate.errors[:validation_url].none?, "border-red-400 focus:outline-red-600": certificate.errors[:validation_url].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :description %>
    <%= form.textarea :description, rows: 4, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": certificate.errors[:description].none?, "border-red-400 focus:outline-red-600": certificate.errors[:description].any?}] %>
  </div>

  <div class="inline">
    <%= form.submit class: "w-full sm:w-auto rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white inline-block font-medium cursor-pointer" %>
  </div>

  <div class="my-5">
    <%= form.label :image, "Imagem do Certificado" %>
    <%= form.file_field :image, class: "block shadow rounded-md border border-gray-400 outline-none px-3 py-2 mt-2 w-full" %>
  </div>

<% end %>
